<jasperReport name="ReporteCita" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="f338dc03-e112-473b-bb71-57fa515c9922">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Sistema_Citas"/>
	<parameter name="id_cita" class="java.lang.Integer"/>
	<parameter name="logo" class="java.io.InputStream"/>
	<query language="SQL"><![CDATA[SELECT 
    p.nombres || ' ' || p.apellidos AS nombre_paciente,
    p.dni,
    d.nombres || ' ' || d.apellidos AS nombre_doctor,
    e.nombre AS especialidad,
    pr.monto AS precio,
    pa.metodo_pago,
    c.fecha_cita,
    c.hora_cita
FROM citas c
JOIN pacientes p ON c.id_paciente = p.id_paciente
JOIN doctores d ON c.id_doctor = d.id_doctor
JOIN especialidades e ON d.id_especialidad = e.id_especialidad
JOIN precios pr ON e.id_especialidad = pr.id_especialidad
JOIN pagos pa ON c.id_cita = pa.id_cita
WHERE c.id_cita = $P{id_cita}]]></query>
