	<parameter name="logo" class="java.io.InputStream"/>
	<query language="SQL"><![CDATA[SELECT d.dni, d.nombres, d.apellidos, d.telefono, d.correo, e.nombre as especialidad 
FROM doctores d 
JOIN especialidades e ON d.id_especialidad = e.id_especialidad 
WHERE d.activo = true]]></query>
