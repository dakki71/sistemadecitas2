<jasperReport name="Reporte" language="java" columnCount="1" pageWidth="760" pageHeight="595" columnWidth="720" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="073666a3-80c7-4b8e-9dcc-f2856ffd6ff5">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="SistemaCitas"/>
	<parameter name="logo" class="java.io.InputStream"/>
	<query language="SQL"><![CDATA[SELECT 
    e.nombre,
    e.descripcion,
    e.activo,
    COUNT(DISTINCT d.id_doctor) AS total_doctores,
    COUNT(DISTINCT c.id_cita)   AS total_citas
FROM especialidades e
LEFT JOIN doctores d ON d.id_especialidad = e.id_especialidad AND d.activo = true
LEFT JOIN citas    c ON c.id_doctor = d.id_doctor
GROUP BY e.id_especialidad, e.nombre, e.descripcion, e.activo
ORDER BY e.nombre ASC]]></query>
