		<property name="com.jaspersoft.studio.field.label" value="total_doctores"/>
	</field>
	<field name="total_citas" class="java.lang.Long">
		<property name="com.jaspersoft.studio.field.name" value="total_citas"/>
		<property name="com.jaspersoft.studio.field.label" value="total_citas"/>
	</field>
